# Database — any Postgres works (Neon, Supabase, Railway, RDS, local)
DATABASE_URL="postgresql://user:password@localhost:5432/vantageflow"

# NextAuth — generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me"
NEXTAUTH_URL="http://localhost:3000"

# Optional: Google sign-in. Omit both to hide the option; email/password
# always works via the credentials provider.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Stripe — from https://dashboard.stripe.com/apikeys (use test keys for dev).
# Enable Apple Pay / Google Pay / PayPal as payment methods in the Stripe
# Dashboard and they'll appear in checkout automatically, no code changes.
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
